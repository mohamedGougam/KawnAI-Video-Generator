# Copy to `backend/.env` for local development.

HF_MODEL_ID=Wan-AI/Wan2.1-T2V-1.3B-Diffusers
# cuda | cpu | auto — use `auto` locally; Render uses `auto` (CPU) unless you use a GPU machine.
DEVICE=auto
DEFAULT_RESOLUTION=720p
DEFAULT_ASPECT_RATIO=9:16
MAX_DURATION_SECONDS=5
GENERATED_VIDEO_DIR=generated/videos
GENERATED_THUMBNAIL_DIR=generated/thumbnails
DATABASE_PATH=generated/metadata/videos.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEFAULT_FPS=16

# Optional: Redis URL for ARQ job queue (API enqueues; worker runs inference). Same container
# start.sh also launches `arq app.worker_settings.WorkerSettings` when this is set.
# REDIS_URL=redis://default:password@redis-host:6379

# Refuse generation when free RAM is below this (MiB). Wan on CPU needs a large instance.
MIN_AVAILABLE_RAM_MB=3800

# Optional: Hugging Face token for gated models / higher rate limits
# HF_TOKEN=

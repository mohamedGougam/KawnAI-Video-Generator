# Copy to `.env` and adjust values.
#
# VIDEO_PROVIDER:
#   mock — no GPU; synthesizes a short placeholder clip (or copies MOCK_SAMPLE_VIDEO_PATH).
#   huggingface — loads Diffusers Wan pipeline (requires CUDA for practical runs).

VIDEO_PROVIDER=mock
HF_MODEL_ID=Wan-AI/Wan2.1-T2V-1.3B-Diffusers
DEVICE=cuda
DEFAULT_RESOLUTION=720p
DEFAULT_ASPECT_RATIO=9:16
MAX_DURATION_SECONDS=10
GENERATED_VIDEO_DIR=generated/videos
GENERATED_THUMBNAIL_DIR=generated/thumbnails
DATABASE_PATH=generated/metadata/videos.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEFAULT_FPS=16

# Optional: absolute path to an MP4 the mock provider should copy instead of synthesizing.
# MOCK_SAMPLE_VIDEO_PATH=C:\\path\\to\\sample.mp4
